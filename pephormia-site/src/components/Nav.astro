---
import Mark from './Mark.astro';
---
<header class="bar"><div class="wrap">
  <a class="brand" href="/"><Mark size={28} /><span class="wm">PEPHORMIA</span></a>
  <nav class="top">
    <a href="/learn/">Learn</a>
    <a href="/library/">Library</a>
    <a href="/shop/">Shop</a>
    <a href="/blog/">Blog</a>
    <a class="btn sm" href="/#briefing">Subscribe</a>
  </nav>
</div></header>
<style>
  .bar{position:sticky;top:0;z-index:50;background:rgba(11,13,16,.82);backdrop-filter:blur(10px);border-bottom:1px solid var(--line)}
  .bar .wrap{display:flex;align-items:center;justify-content:space-between;height:64px}
  .brand{display:flex;align-items:center;gap:11px}
  .brand:hover{text-decoration:none}
  .brand .wm{font-family:var(--font-display);font-weight:700;font-size:17px;letter-spacing:.02em;color:var(--cream)}
  nav.top{display:flex;align-items:center;gap:26px}
  nav.top a{color:var(--soft);font-size:14px;font-weight:500}
  nav.top a:hover{color:var(--cream);text-decoration:none}
  @media(max-width:820px){nav.top a:not(.btn){display:none}}
</style>
