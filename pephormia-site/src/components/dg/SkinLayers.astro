---
const { caption = "The gap: a topical reaches the surface; collagen lives deep in the dermis" } = Astro.props;
---
<figure class="dg">
  <svg viewBox="0 0 420 260" role="img" aria-label={caption}>
    <rect x="60" y="30" width="300" height="34" fill="rgba(76,107,255,.12)" stroke="#4C6BFF" stroke-width="1.5"/>
    <rect x="60" y="64" width="300" height="52" fill="#12151B" stroke="#2A2F3A" stroke-width="1.4"/>
    <rect x="60" y="116" width="300" height="96" fill="rgba(34,197,139,.10)" stroke="#22C58B" stroke-width="1.5"/>
    <g font-family="'IBM Plex Mono',monospace" font-size="10" fill="#9AA1AE">
      <text x="72" y="51">SURFACE · serum sits here</text>
      <text x="72" y="94">EPIDERMIS</text>
      <text x="72" y="168" fill="#22C58B">DERMIS · collagen &amp; fibroblasts</text>
    </g>
    <path d="M210 18 L210 60" stroke="#6D86FF" stroke-width="2" marker-end="url(#a)"/>
    <path d="M300 70 L300 150" stroke="#D68A4E" stroke-width="1.6" stroke-dasharray="4 5" marker-end="url(#b)"/>
    <text x="306" y="115" font-family="'IBM Plex Mono',monospace" font-size="9.5" fill="#D68A4E">the leap</text>
    <defs>
      <marker id="a" markerWidth="8" markerHeight="8" refX="4" refY="4" orient="auto"><path d="M0 0 L8 4 L0 8 Z" fill="#6D86FF"/></marker>
      <marker id="b" markerWidth="8" markerHeight="8" refX="4" refY="4" orient="auto"><path d="M0 0 L8 4 L0 8 Z" fill="#D68A4E"/></marker>
    </defs>
  </svg>
  <figcaption>{caption}</figcaption>
</figure>
