---
const { caption = "GHK-Cu — Gly-His-Lys coordinating a copper ion" } = Astro.props;
---
<figure class="dg">
  <svg viewBox="0 0 420 260" role="img" aria-label={caption}>
    <path d="M78 132 L170 84 L262 132 M262 132 L354 84" fill="none" stroke="#6D86FF" stroke-width="2.6"/>
    <path d="M170 84 L216 188 M262 132 L216 188 M354 84 L216 188" fill="none" stroke="#D68A4E" stroke-width="1.5" stroke-dasharray="4 5"/>
    <g font-family="'Space Grotesk',sans-serif" font-weight="700" text-anchor="middle">
      <circle cx="78" cy="132" r="27" fill="#16203A" stroke="#6D86FF" stroke-width="2.2"/><text x="78" y="141" font-size="22" fill="#9FB3FF">G</text>
      <circle cx="170" cy="84" r="27" fill="#16203A" stroke="#6D86FF" stroke-width="2.2"/><text x="170" y="93" font-size="22" fill="#9FB3FF">H</text>
      <circle cx="262" cy="132" r="27" fill="#16203A" stroke="#6D86FF" stroke-width="2.2"/><text x="262" y="141" font-size="22" fill="#9FB3FF">K</text>
      <circle cx="216" cy="188" r="24" fill="#2A1E14" stroke="#D68A4E" stroke-width="2.2"/><text x="216" y="194" font-size="15" fill="#E0A46A">Cu²⁺</text>
    </g>
    <g font-family="'IBM Plex Mono',monospace" font-size="10.5" fill="#6B7280" text-anchor="middle">
      <text x="78" y="176">Gly</text><text x="170" y="42">His</text><text x="262" y="176">Lys</text>
    </g>
  </svg>
  <figcaption>{caption}</figcaption>
</figure>
