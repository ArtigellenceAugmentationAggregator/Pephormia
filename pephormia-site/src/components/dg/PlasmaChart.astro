---
const { caption = "Plasma GHK falls ~60% from age 20 to 60 (ng/mL)" } = Astro.props;
---
<figure class="dg">
  <svg viewBox="0 0 420 250" role="img" aria-label={caption}>
    <line x1="70" y1="30" x2="70" y2="200" stroke="#2A2F3A" stroke-width="1.4"/>
    <line x1="70" y1="200" x2="390" y2="200" stroke="#2A2F3A" stroke-width="1.4"/>
    <g font-family="'IBM Plex Mono',monospace" font-size="10" fill="#6B7280">
      <text x="40" y="52">200</text><text x="40" y="122">140</text><text x="40" y="192">80</text>
      <text x="88" y="220">age 20</text><text x="330" y="220">age 60</text>
    </g>
    <polygon points="100,44 360,184 360,200 100,200" fill="#4C6BFF" opacity="0.14"/>
    <line x1="100" y1="44" x2="360" y2="184" stroke="#6D86FF" stroke-width="2.6"/>
    <circle cx="100" cy="44" r="4.5" fill="#6D86FF"/><circle cx="360" cy="184" r="4.5" fill="#6D86FF"/>
    <text x="205" y="102" font-family="'IBM Plex Mono',monospace" font-size="10" fill="#22C58B" transform="rotate(9 205 102)">~60% decline</text>
  </svg>
  <figcaption>{caption}</figcaption>
</figure>
