---
// The signature graded-evidence component. Tier: strong | human | weak | mechanistic
const { tier = 'human', claim = '', note = '' } = Astro.props;
const map = {
  strong:      { c: 'var(--green)',  label: 'STRONG' },
  human:       { c: 'var(--cobalt)', label: 'HUMAN' },
  weak:        { c: 'var(--amber)',  label: 'WEAK' },
  mechanistic: { c: 'var(--faint)',  label: 'MECHANISTIC' },
};
const t = map[tier] ?? map.human;
---
<div class="ebox" style={`--tier:${t.c}`}>
  <span class="tag">{t.label}</span>
  <div class="body">
    <p class="claim">{claim}</p>
    {note && <p class="note">{note}</p>}
  </div>
</div>
<style>
  .ebox{display:flex;gap:14px;border:1px solid var(--line);border-left:3px solid var(--tier);background:var(--panel);padding:14px 16px;margin:12px 0}
  .tag{font-family:var(--mono);font-size:9.5px;letter-spacing:.12em;color:var(--tier);padding-top:2px;white-space:nowrap}
  .claim{font-size:14px;color:var(--text)}
  .note{font-family:var(--mono);font-size:11px;color:var(--faint);margin-top:6px;line-height:1.5}
</style>
