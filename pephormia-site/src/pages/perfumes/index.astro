---
import Base from '../../layouts/Base.astro';

// PEPHORMIA × Deon Pro — fragrance preview catalogue. DUMMY listings, white-label, own-brand names.
// Description-only scent copy. No designer references. Full range by Diwali 2026.
const cats = ['All','Attars','Eau de Parfum','Eau de Toilette','Extrait','Gift & Discovery'];
const products = [
  { name:'Rose Taif Attar', fam:'Floral · Rose', for:'Unisex', size:'6 ml oil', price:'AU$12', notes:'A soft, dewy rose with a warm resin drydown. Alcohol-free, long-wearing on skin.', cat:'Attars', hero:false },
  { name:'Oudh Noir Attar', fam:'Woody · Oud', for:'Unisex', size:'6 ml oil', price:'AU$18', notes:'Smoky oud over amber and a whisper of saffron. Deep, concentrated, a little goes far.', cat:'Attars', hero:true },
  { name:'Citrus Marine EDT', fam:'Fresh · Aromatic', for:'Him', size:'50 ml', price:'AU$39', notes:'Bright bergamot and sea-salt air over clean cedar. An everyday, easy-wear fresh.', cat:'Eau de Toilette', hero:false },
  { name:'Velvet Rose EDP', fam:'Floral · Gourmand', for:'Her', size:'50 ml', price:'AU$59', notes:'Rose and lychee wrapped in vanilla and soft musk. Rounded, warm, feminine.', cat:'Eau de Parfum', hero:true },
  { name:'Midnight Oud EDP', fam:'Woody · Amber', for:'Unisex', size:'50 ml', price:'AU$79', notes:'Oud, amber and leather with a smoky incense heart. An evening signature.', cat:'Eau de Parfum', hero:true },
  { name:'Solaire EDP', fam:'Warm · Spicy', for:'Unisex', size:'50 ml', price:'AU$89', notes:'Golden amber, tonka and a dry spice trail. Radiant and enveloping.', cat:'Eau de Parfum', hero:false },
  { name:'Noir Extrait de Parfum', fam:'Woody · Oriental', for:'Unisex', size:'50 ml', price:'AU$149', notes:'A concentrated extrait — oud, rose and dark resins at full depth. Hours of sillage.', cat:'Extrait', hero:false },
  { name:'Réserve Oud Extrait', fam:'Woody · Oud', for:'Unisex', size:'50 ml', price:'AU$499', notes:'The house anchor: aged-oud accord, amber and precious woods. Small-batch, numbered.', cat:'Extrait', hero:true },
  { name:'Discovery Set — 6 × 2 ml', fam:'Sampler', for:'Unisex', size:'6 × 2 ml', price:'AU$29', notes:'Six of the range in travel sprays — the easiest way to find your signature.', cat:'Gift & Discovery', hero:false },
  { name:'Signature Trio Gift Set', fam:'Gift', for:'Unisex', size:'3 × 30 ml', price:'AU$99', notes:'Three bestsellers, boxed. Ready to gift with a compliant, elegant presentation.', cat:'Gift & Discovery', hero:false },
];
---
<Base title="Perfumes — PEPHORMIA × Deon Pro" description="Attars and perfumes, white-labelled and honestly described. A Deon Pro line, on PEPHORMIA. Full range by Diwali 2026.">
  <section class="pad perf">
    <div class="wrap">
      <div class="coord"><span>SYS · DEON PRO / FRAGRANCE</span><span class="r">PEPHORMIA × DEON PRO</span></div>
      <span class="eyebrow gold">Attars &amp; perfumes</span>
      <h1 style="margin:12px 0 12px">Scent, <em>honestly made.</em></h1>
      <p class="sub" style="font-size:19px;max-width:60ch">A Deon Pro line — premium attars and perfumes, white-labelled from a trusted partner and described by how they smell, not who they copy. From everyday oils to a numbered extrait.</p>

      <div class="preview-banner">
        <span class="pb-dot"></span>
        <span><b>Preview catalogue.</b> Full range lands by <b>Diwali 2026</b>. Prices indicative — join the list for launch access and first-batch pricing.</span>
      </div>

      <div class="chips">
        {cats.map((c,i) => <span class={`chip ${i===0?'on':''}`}>{c}</span>)}
      </div>

      <div class="pgrid">
        {products.map(p => (
          <div class={`pcard ${p.hero?'hero':''}`}>
            <div class="shot">
              <svg viewBox="0 0 80 120" aria-hidden="true">
                <rect x="30" y="6" width="20" height="10" rx="2" fill="none" stroke="#D68A4E" stroke-width="2"/>
                <rect x="34" y="16" width="12" height="7" fill="none" stroke="#D68A4E" stroke-width="1.6"/>
                <path d="M24 23 h32 a6 6 0 0 1 6 6 v78 a6 6 0 0 1 -6 6 h-32 a6 6 0 0 1 -6 -6 v-78 a6 6 0 0 1 6 -6 z" fill="rgba(214,138,78,.08)" stroke="#D68A4E" stroke-width="2"/>
                <path d="M40 40 v52 M28 66 h24" stroke="#E0A46A" stroke-width="1.4" opacity=".65"/>
              </svg>
              {p.hero && <span class="badge">Bestseller</span>}
            </div>
            <div class="pbody">
              <div class="ptop"><h3>{p.name}</h3><span class="price">{p.price}</span></div>
              <div class="pmeta">{p.fam} · {p.for} · {p.size}</div>
              <p class="notes">{p.notes}</p>
              <a class="btn sm notify" href="/#briefing">Notify me at launch</a>
            </div>
          </div>
        ))}
      </div>

      <div class="why">
        <div class="why-head">Why Deon Pro</div>
        <div class="why-grid">
          <div class="w"><span class="wn">White-label, zero-inventory</span><p>Made and shipped by a trusted fulfilment partner — no warehouse, no minimums to carry.</p></div>
          <div class="w"><span class="wn">IFRA-aligned, AU-compliant</span><p>Formulated to IFRA standards; labelled to the AU Cosmetics Information Standard.</p></div>
          <div class="w"><span class="wn">Own-brand, not dupes</span><p>Described by scent family and notes — never by another house's name. Ownable, defensible.</p></div>
          <div class="w"><span class="wn">$12 to $499</span><p>Everyday attars to a numbered extrait — a ladder from first-try to signature.</p></div>
        </div>
      </div>

      <div class="honest gold-note" style="margin-top:40px;max-width:860px">
        <span class="k">Compliance line</span>
        <p>Fragrances are described by scent family and notes only — no comparison to, or naming of, any third-party brand. Cosmetic products, not therapeutic goods. Ingredient and allergen labelling per the AU Cosmetics Information Standard 2020.</p>
      </div>
    </div>
  </section>
</Base>

<style>
  .perf .eyebrow.gold{color:var(--copper)}
  .perf h1 em{color:var(--copper)}
  .preview-banner{display:flex;gap:12px;align-items:flex-start;background:rgba(214,138,78,.10);border:1px solid rgba(214,138,78,.34);border-radius:var(--r-sm);padding:14px 18px;margin:24px 0 28px;font-size:14px;color:var(--cream);max-width:860px}
  .preview-banner b{color:var(--copper)}
  .pb-dot{width:8px;height:8px;border-radius:50%;background:var(--copper);margin-top:6px;flex:none;box-shadow:0 0 0 3px rgba(214,138,78,.18)}

  .chips{display:flex;gap:9px;flex-wrap:wrap;margin-bottom:30px}
  .chip{font-family:var(--font-mono);font-size:11.5px;letter-spacing:.04em;color:var(--soft);border:1px solid var(--line-2);border-radius:20px;padding:7px 14px}
  .chip.on{color:#0B0D10;background:var(--copper);border-color:var(--copper)}

  .pgrid{display:grid;grid-template-columns:repeat(4,1fr);gap:18px}
  .pcard{background:var(--bg-2);border:1px solid var(--line);border-radius:var(--r);overflow:hidden;display:flex;flex-direction:column}
  .pcard.hero{border-top:2px solid var(--copper)}
  .shot{position:relative;background:radial-gradient(120% 100% at 30% 10%, #17130f 0%, #0d1016 100%);display:flex;align-items:center;justify-content:center;padding:20px 0;border-bottom:1px solid var(--line)}
  .shot svg{height:118px;width:auto}
  .badge{position:absolute;top:12px;left:12px;font-family:var(--font-mono);font-size:9.5px;letter-spacing:.1em;text-transform:uppercase;color:var(--copper);background:rgba(214,138,78,.14);border-radius:5px;padding:3px 8px}
  .pbody{padding:16px 16px 18px;display:flex;flex-direction:column;gap:7px}
  .ptop{display:flex;justify-content:space-between;align-items:baseline;gap:10px}
  .ptop h3{font-family:var(--font-display);font-weight:600;font-size:15.5px;color:var(--cream)}
  .price{font-family:var(--font-display);font-weight:700;font-size:15px;color:var(--copper);white-space:nowrap}
  .pmeta{font-family:var(--font-mono);font-size:10px;letter-spacing:.03em;color:var(--soft-2)}
  .notes{font-size:12.5px;color:var(--soft);flex:1;line-height:1.5}
  .notify{align-self:flex-start;margin-top:4px;background:transparent;color:var(--cream);border-color:var(--line-2)}
  .notify:hover{border-color:var(--copper);background:rgba(214,138,78,.08)}
  @media(max-width:1000px){.pgrid{grid-template-columns:repeat(2,1fr)}}
  @media(max-width:560px){.pgrid{grid-template-columns:1fr}}

  .why{margin-top:48px;border-top:1px solid var(--line);padding-top:30px}
  .why-head{font-family:var(--font-mono);font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:var(--copper);margin-bottom:20px}
  .why-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:20px}
  .w .wn{font-family:var(--font-display);font-weight:600;font-size:14.5px;color:var(--cream);display:block;margin-bottom:6px}
  .w p{font-size:13px;color:var(--soft)}
  @media(max-width:860px){.why-grid{grid-template-columns:1fr 1fr}}
  @media(max-width:520px){.why-grid{grid-template-columns:1fr}}

  .gold-note{background:rgba(214,138,78,.08);border-left:3px solid var(--copper)}
  .gold-note .k{color:var(--copper)}
</style>
