---
import Base from '../../layouts/Base.astro';
---
<Base title="Shop — PEPHORMIA" description="Cosmetic-grade topical formulations, described by appearance. No prescriptions, ever.">
  <section class="pad">
    <div class="wrap">
      <span class="eyebrow">The shop</span>
      <h2>Cosmetic-grade, <em>no prescriptions.</em></h2>
      <p class="sub">We only sell what we can sell honestly and legally: topical formulations described by how they make skin look. Every product links back to its graded evidence review.</p>
      <ul class="rules">
        <li><span class="tick">✓</span> Appearance claims only — "improves the look of firmness," never "boosts collagen."</li>
        <li><span class="tick">✓</span> INCI / generic names on every product — no third-party trademarks.</li>
        <li><span class="tick">✓</span> No injectable, scheduled, or prescription compounds — ever.</li>
      </ul>
      <div class="honest" style="margin-top:26px;max-width:640px"><span class="k">Launching with the library</span><p>First drop: cosmetic-grade copper-peptide topicals, paired with <em>Copper Peptides, Decoded</em>. <a href="/#briefing">Subscribe for first access.</a></p></div>
    </div>
  </section>
</Base>
<style>
  .rules{list-style:none;margin-top:24px;max-width:640px}
  .rules li{display:flex;gap:11px;padding:11px 0;font-size:15px;border-top:1px solid var(--line)}
  .rules li:first-child{border-top:0}
  .rules .tick{color:var(--green);font-weight:700}
</style>
