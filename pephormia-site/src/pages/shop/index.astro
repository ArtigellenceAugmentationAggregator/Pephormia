---
import Base from '../../layouts/Base.astro';

// Agreed catalogue (from the launch-plan research). DUMMY listings — store opens with the library.
// INCI / appearance-claim only. No third-party trademarks, no compound/category names.
const heroes = [
  { name:'Copper Peptide Serum', inci:'Copper Tripeptide-1 0.2% · Ubiquinone · Niacinamide', claim:'For the look of firmer, brighter, more even-toned skin.', price:'AU$39', review:'/learn/skin/' },
  { name:'Peptide Lash & Brow Serum', inci:'Myristoyl Pentapeptide-17 · Hexapeptide-11', claim:'Conditions lashes and brows for a fuller, healthier-looking finish.', price:'AU$49', review:'/learn/skin/' },
  { name:'Anti-Age Peptide Serum', inci:'Palmitoyl Tripeptide-1 · Palmitoyl Tetrapeptide-7', claim:'Smooths the appearance of fine lines for a plumper look.', price:'AU$39', review:'/learn/skin/' },
];
const rollout = [
  { name:'Peptide Firming Eye Cream', inci:'Peptide complex · Caffeine', claim:'Targets the look of puffiness and fine lines around the eye.', price:'AU$35' },
  { name:'Vegan Collagen Serum', inci:'Plant collagen · Sodium Hyaluronate', claim:'For visibly hydrated, bouncier-looking skin.', price:'AU$33' },
  { name:'Squalane Face Oil', inci:'Squalane', claim:'Lightweight finishing oil for a soft, dewy look.', price:'AU$25' },
  { name:'Vitamin C Serum', inci:'Sodium Ascorbyl Phosphate', claim:'For a brighter, more radiant-looking complexion.', price:'AU$29' },
  { name:'Hyaluronic Serum', inci:'Sodium Hyaluronate (multi-weight)', claim:'Deep-looking hydration and a plumped appearance.', price:'AU$29' },
  { name:'Niacinamide Serum', inci:'Niacinamide 10% · Zinc PCA', claim:'For the look of refined pores and even tone.', price:'AU$29' },
];
const digital = [
  { name:'AM/PM Skincare Routine Tracker', price:'AU$7' },
  { name:'90-Day Glow-Up Journal', price:'AU$9' },
  { name:'Copper Peptide Starter Guide', price:'AU$12', note:'free version in the Library' },
];
---
<Base title="Shop — PEPHORMIA" description="Cosmetic-grade topical formulations, described by appearance. AU-made. No prescriptions, ever.">
  <section class="pad">
    <div class="wrap">
      <div class="coord"><span>SYS · SHOP / CATALOGUE</span><span class="r">COSMETIC-GRADE · AU-MADE</span></div>
      <span class="eyebrow">The shop</span>
      <h2 style="margin-top:12px">Cosmetic-grade, <em>no prescriptions.</em></h2>
      <p class="sub">Topical formulations described by how they make skin look — each linked to its graded evidence review. AU-made by an ISO 22716 lab, vegan and cruelty-free.</p>

      <div class="preview-banner">
        <span class="pb-dot"></span>
        <span><b>Preview catalogue.</b> The store opens alongside the Library. Prices indicative; join the list for first-drop access and launch pricing.</span>
      </div>

      <!-- HERO / FIRST DROP -->
      <div class="block-head"><h3 class="bh">First drop · hero line</h3><span class="count">3 SKUs</span></div>
      <div class="pgrid">
        {heroes.map(p => (
          <div class="pcard hero">
            <div class="shot">
              <svg viewBox="0 0 80 120" aria-hidden="true"><rect x="26" y="8" width="28" height="12" rx="2" fill="none" stroke="#4C6BFF" stroke-width="2"/><rect x="30" y="20" width="20" height="8" fill="none" stroke="#6D86FF" stroke-width="1.6"/><rect x="18" y="28" width="44" height="82" rx="8" fill="rgba(76,107,255,.10)" stroke="#4C6BFF" stroke-width="2"/><path d="M40 46 L40 92 M28 62 L52 62" stroke="#22C58B" stroke-width="1.6" opacity=".7"/></svg>
              <span class="badge">Hero</span>
            </div>
            <div class="pbody">
              <h4>{p.name}</h4>
              <div class="inci">{p.inci}</div>
              <p class="claim">{p.claim}</p>
              <div class="prow"><span class="price">{p.price}</span><a class="rev" href={p.review}>evidence →</a></div>
              <a class="btn sm notify" href="/#briefing">Notify me at launch</a>
            </div>
          </div>
        ))}
      </div>

      <!-- ROLLOUT -->
      <div class="block-head" style="margin-top:44px"><h3 class="bh">Rolling out</h3><span class="count">as traction proves</span></div>
      <div class="rgrid">
        {rollout.map(p => (
          <div class="rcard">
            <div class="rtop"><h4>{p.name}</h4><span class="rprice">{p.price}</span></div>
            <div class="inci">{p.inci}</div>
            <p class="claim">{p.claim}</p>
            <span class="soon">Rolling out soon</span>
          </div>
        ))}
      </div>

      <!-- DIGITAL -->
      <div class="block-head" style="margin-top:44px"><h3 class="bh">Digital &amp; print</h3><span class="count">instant delivery</span></div>
      <div class="dgrid">
        {digital.map(d => (
          <a class="dcard" href="/library/">
            <div class="drow"><span class="dname">{d.name}</span><span class="dprice">{d.price}</span></div>
            {d.note && <span class="dnote">{d.note}</span>}
            <span class="dgo">In the Library →</span>
          </a>
        ))}
      </div>

      <div class="honest" style="margin-top:44px;max-width:820px">
        <span class="k">How it stays compliant</span>
        <p>Appearance claims only — never "boosts collagen." INCI / generic ingredient names, no third-party trademarks. No injectable, scheduled, or prescription compounds, ever. Every product links to its graded evidence review so you buy on the science, not the hype.</p>
      </div>
    </div>
  </section>
</Base>

<style>
  .preview-banner{display:flex;gap:12px;align-items:flex-start;background:var(--wash);border:1px solid rgba(76,107,255,.3);border-radius:var(--r-sm);padding:14px 18px;margin:26px 0 40px;font-size:14px;color:var(--cream);max-width:820px}
  .preview-banner b{color:var(--accent-2)}
  .pb-dot{width:8px;height:8px;border-radius:50%;background:var(--green);margin-top:6px;flex:none;box-shadow:0 0 0 3px rgba(34,197,139,.18)}

  .block-head{display:flex;align-items:center;gap:12px;padding-bottom:12px;margin-bottom:20px;border-bottom:1px solid var(--line)}
  .bh{font-size:16px;font-family:var(--font-display)}
  .count{font-family:var(--font-mono);font-size:11px;color:var(--soft-2);border:1px solid var(--line-2);border-radius:20px;padding:2px 9px}

  .pgrid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px}
  .pcard{background:var(--bg-2);border:1px solid var(--line);border-radius:var(--r);overflow:hidden;display:flex;flex-direction:column}
  .pcard.hero{border-top:2px solid var(--accent)}
  .shot{position:relative;background:radial-gradient(120% 100% at 30% 10%, #12151b 0%, #0d1016 100%);display:flex;align-items:center;justify-content:center;padding:22px 0;border-bottom:1px solid var(--line)}
  .shot svg{height:120px;width:auto}
  .badge{position:absolute;top:12px;left:12px;font-family:var(--font-mono);font-size:9.5px;letter-spacing:.1em;text-transform:uppercase;color:var(--accent-2);background:var(--wash);border-radius:5px;padding:3px 8px}
  .pbody{padding:18px 18px 20px;display:flex;flex-direction:column;gap:8px}
  .pbody h4{font-family:var(--font-display);font-weight:600;font-size:17px;color:var(--cream)}
  .inci{font-family:var(--font-mono);font-size:10.5px;letter-spacing:.02em;color:var(--soft-2);line-height:1.5}
  .claim{font-size:13.5px;color:var(--soft);flex:1}
  .prow{display:flex;align-items:center;justify-content:space-between;margin-top:4px}
  .price{font-family:var(--font-display);font-weight:700;font-size:20px;color:var(--cream)}
  .rev{font-family:var(--font-mono);font-size:11px;color:var(--accent-2)}
  .notify{align-self:flex-start;margin-top:6px}
  @media(max-width:860px){.pgrid{grid-template-columns:1fr}}

  .rgrid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
  .rcard{background:var(--bg-2);border:1px solid var(--line);border-radius:var(--r);padding:18px 18px 16px;display:flex;flex-direction:column;gap:7px}
  .rtop{display:flex;justify-content:space-between;align-items:baseline;gap:10px}
  .rtop h4{font-family:var(--font-display);font-weight:600;font-size:15px;color:var(--cream)}
  .rprice{font-family:var(--font-mono);font-size:13px;color:var(--soft)}
  .rcard .claim{font-size:13px}
  .soon{font-family:var(--font-mono);font-size:10px;letter-spacing:.06em;text-transform:uppercase;color:var(--soft-2)}
  @media(max-width:860px){.rgrid{grid-template-columns:1fr 1fr}}
  @media(max-width:520px){.rgrid{grid-template-columns:1fr}}

  .dgrid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
  .dcard{background:var(--bg-2);border:1px solid var(--line);border-left:3px solid var(--green);border-radius:var(--r-sm);padding:16px 18px;display:flex;flex-direction:column;gap:6px}
  .dcard:hover{background:var(--bg-3);text-decoration:none}
  .drow{display:flex;justify-content:space-between;align-items:baseline;gap:10px}
  .dname{font-family:var(--font-display);font-weight:600;font-size:14.5px;color:var(--cream)}
  .dprice{font-family:var(--font-mono);font-size:13px;color:var(--green)}
  .dnote{font-size:12px;color:var(--soft-2)}
  .dgo{font-family:var(--font-mono);font-size:11px;color:var(--accent-2);margin-top:2px}
  @media(max-width:720px){.dgrid{grid-template-columns:1fr}}
</style>
