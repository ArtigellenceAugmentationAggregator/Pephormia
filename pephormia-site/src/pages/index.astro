---
import BaseLayout from '../layouts/BaseLayout.astro';
import EvidenceBox from '../components/EvidenceBox.astro';
---
<BaseLayout title="PEPHORMIA — Peptides & Hormones, graded and cited">
  <section class="wrap hero">
    <div class="eyebrow">WHOLE-SYSTEM PEPTIDE & HORMONE PLATFORM</div>
    <h1>The signal, not the noise.</h1>
    <p class="sub">PEPHORMIA grades the real peptide & hormone science — strong, human, weak, or mechanistic — so you
      see what the evidence actually says. Then we turn that trusted core into products: cosmetic topicals, cited
      digital guides, and print tools. Honest about limits, by design.</p>
    <div class="cta-row">
      <a class="btn" href="/learn">Explore the science</a>
      <a class="btn ghost" href="/shop">Visit the shop</a>
    </div>
  </section>

  <div class="wrap"><div class="rail"><span>PH.HOME</span><span>4 TIERS</span><span>3 STREAMS</span><span>SYDNEY · AU</span></div></div>

  <section class="wrap block">
    <div class="eyebrow">THE SIGNATURE SYSTEM</div>
    <h2>Every claim, graded honestly.</h2>
    <p class="lead">We don't invent claims — we aggregate peer-reviewed research and tag each finding by how strong the
      evidence really is. This is the four-tier evidence box you'll see across the whole platform.</p>
    <EvidenceBox tier="strong" claim="GHK-Cu supports the look of firmer, smoother skin over a 12-week course." note="Leyden 2005, 67–71 women, 12-week RCT — the stronger human data." />
    <EvidenceBox tier="weak" claim="In one small comparison, topical GHK-Cu raised collagen response in more subjects than vitamin C or retinoic acid." note="Abdulghani 1998, ~10 subjects — small n, treat as preliminary." />
    <EvidenceBox tier="mechanistic" claim="GHK-Cu modulates a broad set of genes tied to repair in cell models." note="Preclinical / in-vitro only — mechanism, not proven human outcome." />
  </section>

  <section class="wrap block">
    <div class="eyebrow">THREE STREAMS</div>
    <h2>One trusted core, three ways to buy.</h2>
    <div class="three">
      <a class="tcard" href="/shop"><div class="s" style="--s:var(--cobalt)"></div><h3>Topicals</h3><p>Cosmetic-grade peptide skincare — appearance-only, INCI-named, AU-made where possible.</p></a>
      <a class="tcard" href="/library"><div class="s" style="--s:var(--green)"></div><h3>Digital</h3><p>Cited evidence guides and PDFs. The full honest picture, graded and sourced.</p></a>
      <a class="tcard" href="/shop"><div class="s" style="--s:var(--copper)"></div><h3>Print</h3><p>Journals, planners and wall art — print-on-demand, ships worldwide.</p></a>
    </div>
  </section>

  <style>
    .hero{padding:70px 0 26px;max-width:900px}
    .hero h1{font-size:52px;line-height:1.05;margin:14px 0 16px}
    .hero .sub{color:var(--muted);font-size:16px;max-width:64ch}
    .cta-row{display:flex;gap:12px;margin-top:26px}
    .btn{font-family:var(--mono);font-size:12px;letter-spacing:.1em;text-transform:uppercase;padding:13px 20px;background:var(--cobalt);color:#fff;transition:.15s}
    .btn:hover{opacity:.9}
    .btn.ghost{background:transparent;border:1px solid var(--line);color:var(--text)}
    .btn.ghost:hover{border-color:var(--cobalt);color:#fff}
    .block{padding:48px 0 0}
    .block h2{font-size:28px;margin:6px 0 8px}
    .lead{color:var(--muted);max-width:64ch;margin-bottom:18px;font-size:14px}
    .three{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--line);border:1px solid var(--line)}
    .tcard{background:var(--panel);padding:22px 20px;transition:background .15s}
    .tcard:hover{background:var(--panel-2)}
    .tcard .s{height:3px;width:40px;background:var(--s);margin-bottom:14px}
    .tcard h3{font-size:19px;margin-bottom:6px}
    .tcard p{font-size:13px;color:var(--muted)}
    @media(max-width:820px){.hero h1{font-size:34px}.three{grid-template-columns:1fr}}
  </style>
</BaseLayout>
