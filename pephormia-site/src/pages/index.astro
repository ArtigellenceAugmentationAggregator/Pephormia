---
import Base from '../layouts/Base.astro';
import EvidenceBox from '../components/EvidenceBox.astro';
import Molecule from '../components/dg/Molecule.astro';
import Pyramid from '../components/dg/Pyramid.astro';
import PlasmaChart from '../components/dg/PlasmaChart.astro';
import SkinLayers from '../components/dg/SkinLayers.astro';
import MechanismFlow from '../components/dg/MechanismFlow.astro';

const goals = [
  { t:'Sleep', d:'Depth, latency, circadian rhythm.', ex:'DSIP · melatonin · glycine', href:'/learn/' },
  { t:'Energy & fatigue', d:'Mitochondrial output, recovery from tired.', ex:'MOTS-c · creatine · CoQ10', href:'/learn/' },
  { t:'Metabolism & weight', d:'Insulin sensitivity, body composition.', ex:'GLP-1 class · MOTS-c', href:'/learn/' },
  { t:'Hormones', d:'The endocrine axis, honestly explained.', ex:'DHEA · thyroid · GH axis', href:'/learn/' },
  { t:'Recovery & repair', d:'Tissue, tendon, wound, post-procedure.', ex:'BPC-157 · TB-500 · GHK-Cu', href:'/learn/' },
  { t:'Focus & cognition', d:'Attention, memory, neuroprotection.', ex:'Semax · Selank', href:'/learn/' },
  { t:'Mood & stress', d:'Stress load, resilience, calm.', ex:'Selank · DSIP', href:'/learn/' },
  { t:'Longevity', d:'Ageing biology — hype vs evidence.', ex:'Epitalon · NAD⁺ · GHK', href:'/learn/' },
  { t:'Skin & hair', d:'One bucket among many — where you can shop.', ex:'GHK-Cu · Matrixyl-class', href:'/shop/' },
];
const peptides = ['BPC-157','TB-500','KPV','MOTS-c','DSIP','Semax','Epitalon'];
const streams = [
  { n:'01', t:'Learn', d:'A graded, cited dossier for every compound: mechanism, human evidence, tier, and the honest "doesn\'t show" line — sourced to primary literature.', k:'Cited · graded', href:'/learn/' },
  { n:'02', t:'Shop', d:'Cosmetic-grade topical formulations only, described by appearance. Never injectable, never scheduled — those stay in Learn as education.', k:'Cosmetic-grade only', href:'/shop/' },
  { n:'03', t:'Tools', d:'Deep evidence reviews, protocol trackers, and reference guides — the digital library that turns the science into something you can use.', k:'Digital + print', href:'/library/' },
];
---
<Base>
  <!-- HERO -->
  <section class="hero-sec grid-bg">
    <div class="wrap">
      <div class="coord"><span>SYS.00 / INDEX</span><span class="r">PEPHORMIA — PEPTIDE &amp; HORMONE INTELLIGENCE</span></div>
      <div class="hero"><div class="grid">
        <div>
          <span class="eyebrow cobalt">The whole-system peptide &amp; hormone platform</span>
          <h1>Peptides and hormones, <em>decoded.</em></h1>
          <p class="lede">Sleep, energy, metabolism, hormones, recovery, focus, longevity — and skin. We read the primary literature, grade how strong the evidence really is, and state plainly what it shows and what it doesn't. Aggregator, not generator.</p>
          <div class="cta-row">
            <a class="btn" href="/#briefing">Read the free FDA briefing →</a>
            <a class="btn ghost" href="/#method">How we grade evidence</a>
          </div>
          <div class="stats">
            <div><div class="n display">4-tier</div><div class="l">Every claim graded strong → mechanistic</div></div>
            <div><div class="n display">100%</div><div class="l">Traced to primary literature</div></div>
            <div><div class="n display">0</div><div class="l">Injectable or scheduled compounds sold</div></div>
          </div>
        </div>
        <EvidenceBox
          title="GHK carries copper into cells"
          tier="strong"
          tierLabel="Primary · mechanism"
          finding="GHK is a growth-modulating plasma tripeptide that facilitates copper uptake into cells; plasma levels fall from ~200 ng/mL at age 20 to ~80 ng/mL by 60."
          source="Pickart et al. Nature 1980;288:715–717 · Pickart & Margolina, Int J Mol Sci 2018."
          doesntShow="That rubbing GHK-Cu on skin reverses that decline — a correlation with ageing is not proof a topical fixes it."
        />
      </div></div>
    </div>
  </section>

  <!-- SPECIMEN READOUT -->
  <section class="pad">
    <div class="wrap">
      <div class="coord"><span>SYS.01 / SPECIMEN READOUT</span><span class="r">GHK-CU · READ IT IN ONE LOOK</span></div>
      <h2>The molecule, and the <em>gap</em> that decides everything.</h2>
      <div class="viz-trio">
        <Molecule caption="GHK-Cu — glycine·histidine·lysine coordinating one Cu²⁺ ion." />
        <PlasmaChart caption="Your own blood makes it — and makes ~60% less by age 60." />
        <SkinLayers caption="A topical reaches the surface; the collagen it targets sits deep in the dermis." />
      </div>
    </div>
  </section>

  <!-- OPTIMISE -->
  <section class="pad grid-bg" id="goals">
    <div class="wrap">
      <div class="coord"><span>SYS.02 / OPTIMISE</span><span class="r">START HERE · PICK A GOAL</span></div>
      <div class="head">
        <h2>What are you trying to <em>optimise?</em></h2>
        <p class="sub" style="max-width:36ch">Peptides and hormones touch the whole system. Each goal opens the graded evidence for it.</p>
      </div>
      <div class="goal-grid">
        {goals.map(g => (
          <a class="goal" href={g.href}>
            <span class="dot"></span><span class="t">{g.t}</span><span class="d">{g.d}</span><span class="ex">{g.ex}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- METHOD -->
  <section class="pad" id="method">
    <div class="wrap">
      <div class="coord"><span>SYS.03 / EVIDENCE METHOD</span><span class="r">HOW WE GRADE</span></div>
      <div class="mgrid">
        <div>
          <h2>Grade the evidence <em>before</em> you believe the claim.</h2>
          <p class="sub">Every effect gets one tier — the honest strength of its human evidence — plus an explicit line on what it <em>doesn't</em> show. For most peptides, the truth lives in the bottom two tiers, and saying so is the whole point.</p>
          <div class="tierlist">
            <div class="t"><span class="tier strong">Strong</span><p>Systematic review, meta-analysis, or RCT — or a mechanism confirmed across independent models.</p></div>
            <div class="t"><span class="tier human">Human</span><p>Controlled or cohort human study, but limited — small samples or appearance-only endpoints.</p></div>
            <div class="t"><span class="tier weak">Weak</span><p>Uncontrolled human, case series, or animal / preclinical. Real science, but not proof in people.</p></div>
            <div class="t"><span class="tier mech">Mechanistic</span><p>In vitro pathway only, with no demonstrated human outcome. Promising is not proven.</p></div>
          </div>
        </div>
        <div class="pyr"><Pyramid caption="Where the seven FDA-hearing peptides mostly sit: near the base." /></div>
      </div>
    </div>
  </section>

  <!-- MECHANISM -->
  <section class="pad grid-bg">
    <div class="wrap">
      <div class="coord"><span>SYS.04 / MECHANISM</span><span class="r">MEASURED VS THE LEAP</span></div>
      <div class="mech-grid">
        <div>
          <h2>What the studies <em>measured</em> — and the leap they didn't.</h2>
          <p class="sub">GHK-Cu touches several real repair pathways. But almost all of it is mapped in cell and animal models. Solid arrows are measured; the dashed one is the claim the marketing makes.</p>
          <div class="honest" style="margin-top:22px"><span class="k">The rule</span><p>Breadth of mechanism is not proof of a facial outcome. Every pathway carries its own tier.</p></div>
        </div>
        <MechanismFlow caption="Solid = measured in models. Dashed = the unproven leap to reverses ageing." />
      </div>
    </div>
  </section>

  <!-- PLATFORM (numbered instrument cards) -->
  <section class="pad" id="streams">
    <div class="wrap">
      <div class="coord"><span>SYS.05 / PLATFORM</span><span class="r">THREE WAYS IN</span></div>
      <div class="stream-grid">
        {streams.map(s => (
          <a class="numcard" href={s.href}>
            <span class="n">{s.n} · {s.t.toUpperCase()}</span>
            <h3>{s.t}</h3>
            <p>{s.d}</p>
            <span class="k">{s.k}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- REGULATORY WATCH -->
  <section class="pad" id="hearing">
    <div class="wrap">
      <div class="coord"><span>SYS.06 / REGULATORY WATCH</span><span class="r">FDA PCAC · 23–24 JUL 2026</span></div>
      <h2>The FDA peptide hearing, <em>explained.</em></h2>
      <div class="fda-panel">
        <div class="date"><div class="d display">23–24</div><div class="m">Jul 2026</div></div>
        <div>
          <h3>Pharmacy Compounding Advisory Committee · docket FDA-2025-N-6895</h3>
          <p>An advisory vote on whether seven peptides belong on the 503A compounding list — not approval, not consumer legalisation. We track it in plain, graded language, with no prediction dressed as news.</p>
          <div class="chips">{peptides.map(p => <span class="chip">{p}</span>)}</div>
        </div>
        <a class="btn" href="/#briefing">Get the briefing →</a>
      </div>
    </div>
  </section>

  <!-- CAPTURE -->
  <section class="pad" id="briefing">
    <div class="wrap">
      <div class="coord"><span>SYS.07 / CAPTURE</span><span class="r">THE BRIEFING</span></div>
      <div class="news-panel grid-bg">
        <h2>One email a week. The science, decoded.</h2>
        <p>New evidence, one compound decoded, and the regulatory watch — sourced, graded, hype-free. Subscribe and the FDA-hearing briefing lands in your inbox.</p>
        <div class="beehiiv-slot">
          &lt;!-- BEEHIIV EMBED SLOT --&gt;<br />
          <b>Paste your Beehiiv subscribe embed here.</b><br />Replace with the form HTML from Beehiiv → Publications → Subscribe Forms.
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .hero-sec{border-top:0}
  .hero{padding:26px 0 70px}
  .hero .grid{display:grid;grid-template-columns:1.05fr .95fr;gap:54px;align-items:center}
  .hero h1{margin:16px 0 0}
  .hero .lede{font-size:19px;color:var(--soft);max-width:52ch;margin:18px 0 30px}
  .hero .cta-row{display:flex;gap:13px;flex-wrap:wrap}
  .stats{display:flex;gap:28px;margin-top:38px;flex-wrap:wrap}
  .stats .n{font-size:24px;color:var(--cream)}
  .stats .l{font-size:12.5px;color:var(--soft-2);line-height:1.4;max-width:20ch;font-family:var(--font-body)}
  @media(max-width:860px){.hero .grid{grid-template-columns:1fr;gap:36px}.hero{padding:8px 0 44px}}

  .viz-trio{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:30px}
  @media(max-width:900px){.viz-trio{grid-template-columns:1fr}}

  .head{display:flex;justify-content:space-between;align-items:flex-end;flex-wrap:wrap;gap:16px;margin-bottom:30px}
  .goal-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px}
  .goal{background:var(--bg-2);border:1px solid var(--line);border-radius:var(--r);padding:22px 20px;display:flex;flex-direction:column;gap:6px;transition:.16s}
  .goal:hover{border-color:var(--accent);background:var(--bg-3);transform:translateY(-2px);text-decoration:none}
  .goal .dot{width:10px;height:10px;border-radius:50%;background:linear-gradient(90deg,var(--accent),var(--green));margin-bottom:10px}
  .goal .t{font-family:var(--font-display);font-weight:600;font-size:16px;color:var(--cream)}
  .goal .d{font-size:13px;color:var(--soft)}
  .goal .ex{font-family:var(--font-mono);font-size:10.5px;letter-spacing:.04em;color:var(--soft-2);margin-top:4px}
  @media(max-width:820px){.goal-grid{grid-template-columns:1fr 1fr}}
  @media(max-width:520px){.goal-grid{grid-template-columns:1fr}}

  .mgrid{display:grid;grid-template-columns:1.05fr .95fr;gap:50px;align-items:center}
  .tierlist{margin-top:22px}
  .tierlist .t{display:grid;grid-template-columns:130px 1fr;gap:16px;padding:14px 0;border-top:1px solid var(--line);align-items:start}
  .tierlist .t:first-child{border-top:0}
  .tierlist .t p{font-size:13.5px;color:var(--soft)}
  .pyr{max-width:400px;justify-self:center;width:100%}
  @media(max-width:860px){.mgrid{grid-template-columns:1fr;gap:30px}}

  .mech-grid{display:grid;grid-template-columns:.95fr 1.05fr;gap:48px;align-items:center}
  @media(max-width:860px){.mech-grid{grid-template-columns:1fr;gap:28px}}

  .stream-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}
  .numcard{background:var(--bg-2);border:1px solid var(--line);border-top:2px solid var(--accent);border-radius:0 0 var(--r) var(--r);padding:22px 22px 24px;display:flex;flex-direction:column;gap:8px;transition:.16s}
  .numcard:hover{background:var(--bg-3);text-decoration:none;transform:translateY(-2px)}
  .numcard .n{font-family:var(--font-mono);font-size:11px;letter-spacing:.12em;color:var(--soft-2)}
  .numcard p{color:var(--soft);font-size:14px;margin:2px 0 12px;flex:1}
  .numcard .k{font-family:var(--font-mono);font-size:10.5px;letter-spacing:.1em;text-transform:uppercase;color:var(--green)}
  @media(max-width:860px){.stream-grid{grid-template-columns:1fr}}

  .fda-panel{background:var(--bg-2);border:1px solid var(--line-2);border-radius:var(--r);padding:32px;display:grid;grid-template-columns:auto 1fr auto;gap:28px;align-items:center;margin-top:22px}
  .fda-panel .date{text-align:center;background:var(--wash);border:1px solid rgba(76,107,255,.3);border-radius:var(--r-sm);padding:16px 22px}
  .fda-panel .date .d{font-size:34px;color:var(--cream)}
  .fda-panel .date .m{font-family:var(--font-mono);font-size:10.5px;letter-spacing:.16em;text-transform:uppercase;color:var(--accent-2);margin-top:7px}
  .fda-panel p{color:var(--soft);font-size:14px;margin-top:6px;max-width:58ch}
  .chips{display:flex;gap:7px;flex-wrap:wrap;margin-top:14px}
  .chip{font-family:var(--font-mono);font-size:10.5px;letter-spacing:.04em;color:var(--soft);background:var(--bg-3);border:1px solid var(--line-2);border-radius:5px;padding:5px 9px}
  @media(max-width:820px){.fda-panel{grid-template-columns:1fr}.fda-panel .date{justify-self:start}}

  .news-panel{background:var(--bg-2);border:1px solid var(--line-2);border-radius:var(--r);padding:52px 40px;text-align:center}
  .news-panel h2{max-width:20ch;margin:0 auto 12px}
  .news-panel p{color:var(--soft);max-width:50ch;margin:0 auto 28px;font-size:17px}
  .beehiiv-slot{max-width:560px;margin:0 auto;border:1px dashed var(--line-2);border-radius:var(--r-sm);background:var(--bg);padding:22px;font-family:var(--font-mono);font-size:12.5px;color:var(--soft-2);line-height:1.7}
  .beehiiv-slot b{color:var(--green)}
</style>
