---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(p => ({ params: { slug: p.slug }, props: { post: p } }));
}
const { post } = Astro.props;
const { Content } = await post.render();
---
<BaseLayout title={`${post.data.title} — PEPHORMIA`} description={post.data.description}>
  <article class="wrap art">
    <div class="eyebrow">{post.data.tag ?? 'Article'} · {post.data.date.toISOString().slice(0,10)}</div>
    <h1>{post.data.title}</h1>
    <div class="prose"><Content /></div>
    <a class="back" href="/blog">← All posts</a>
  </article>
  <style>
    .art{max-width:720px;padding:56px 28px 0}
    .art h1{font-size:34px;line-height:1.1;margin:12px 0 22px}
    .prose{color:var(--text);font-size:15px}
    .prose :global(p){margin:0 0 16px}
    .prose :global(strong){color:#fff}
    .prose :global(em){color:var(--muted)}
    .back{display:inline-block;margin-top:24px;font-family:var(--mono);font-size:12px;color:var(--cobalt);letter-spacing:.08em}
  </style>
</BaseLayout>
