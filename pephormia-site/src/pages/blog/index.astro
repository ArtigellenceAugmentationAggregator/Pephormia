---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
const posts = (await getCollection('blog')).sort((a,b)=> b.data.date.valueOf() - a.data.date.valueOf());
---
<BaseLayout title="Blog — PEPHORMIA" description="Cited, honest writing on peptides, hormones and the evidence behind the claims.">
  <section class="wrap head">
    <div class="eyebrow">BLOG / SYS.03</div>
    <h1>Honest writing on a hyped topic.</h1>
    <p class="sub">Cited, graded, no-hype articles across the peptide & hormone system.</p>
  </section>
  <div class="wrap"><div class="rail"><span>PH.BLOG</span><span>{posts.length} POSTS</span><span>CITED · HONEST</span></div></div>
  <section class="wrap list">
    {posts.map(p => (
      <a class="post" href={`/blog/${p.slug}`}>
        <div class="meta"><span class="mono">{p.data.tag ?? 'Article'}</span><span class="mono">{p.data.date.toISOString().slice(0,10)}</span></div>
        <h3>{p.data.title}</h3>
        <p>{p.data.description}</p>
      </a>
    ))}
  </section>
  <style>
    .head{padding:60px 0 22px;max-width:820px}
    .head h1{font-size:40px;margin:12px 0 14px}
    .head .sub{color:var(--muted);font-size:15px}
    .list{margin-top:24px;border-top:1px solid var(--line)}
    .post{display:block;padding:22px 2px;border-bottom:1px solid var(--line);transition:padding-left .15s}
    .post:hover{padding-left:8px}
    .post .meta{display:flex;gap:14px;margin-bottom:8px}
    .post h3{font-size:20px;margin-bottom:6px}
    .post p{font-size:13px;color:var(--muted);max-width:70ch}
  </style>
</BaseLayout>
