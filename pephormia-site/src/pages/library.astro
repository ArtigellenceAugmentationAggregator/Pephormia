---
import BaseLayout from '../layouts/BaseLayout.astro';
const items = [
  ['FREE','7 FDA-Hearing Peptides','Verified clean','The peptides on the regulatory radar, graded and honest. Free with email.','Get it','/#'],
  ['A$19','Copper Peptides (GHK-Cu) Decoded','Cited evidence review','What the peer-reviewed record actually shows for GHK-Cu — every claim tiered and sourced. Final citation pass in progress.','Launching soon','#'],
  ['A$39','The Peptide Evidence Library','Bundle','Every graded evidence review in one bundle — the full honest picture across sleep, recovery, skin, focus and longevity.','Buy','/#'],
];
---
<BaseLayout title="Library — PEPHORMIA" description="Cited, graded digital evidence reviews and downloadable guides.">
  <section class="wrap head">
    <div class="eyebrow">LIBRARY / SYS.02</div>
    <h1>The evidence, downloadable.</h1>
    <p class="sub">Cited evidence reviews you can keep. Each one grades the science honestly and sources every claim —
      no filler, no unverifiable figures.</p>
  </section>
  <div class="wrap"><div class="rail"><span>PH.LIBRARY</span><span>DIGITAL</span><span>CITED · GRADED</span></div></div>
  <section class="wrap grid">
    {items.map(([price,title,tag,desc,cta,href]) => (
      <div class="item">
        <div class="s"></div>
        <span class="tag">{tag}</span>
        <h3>{title}</h3>
        <p>{desc}</p>
        <div class="foot">
          <span class="price" style={price==='A$19' ? 'color:var(--faint)' : ''}>{price==='A$19' ? 'Soon' : price}</span>
          {cta==='Launching soon'
            ? <span class="buy soon">Launching soon</span>
            : <a class="buy" href={href}>{cta}</a>}
        </div>
      </div>
    ))}
  </section>
  <style>
    .head{padding:60px 0 22px;max-width:820px}
    .head h1{font-size:40px;margin:12px 0 14px}
    .head .sub{color:var(--muted);font-size:15px;max-width:64ch}
    .grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--line);border:1px solid var(--line);margin-top:26px}
    .item{background:var(--panel);padding:20px;display:flex;flex-direction:column;min-height:230px}
    .item .s{height:3px;width:40px;background:var(--green);margin-bottom:12px}
    .item .tag{font-family:var(--mono);font-size:10px;color:var(--muted);letter-spacing:.06em;text-transform:uppercase}
    .item h3{font-size:17px;margin:10px 0 6px}
    .item p{font-size:12.5px;color:var(--muted);flex:1}
    .foot{display:flex;align-items:center;justify-content:space-between;border-top:1px solid var(--line);padding-top:14px;margin-top:14px}
    .price{font-family:var(--display);font-weight:700;font-size:18px;color:#fff}
    .buy{font-family:var(--mono);font-size:10.5px;letter-spacing:.1em;text-transform:uppercase;color:var(--green);border:1px solid var(--green);padding:7px 12px;transition:.15s}
    .buy:hover{background:var(--green);color:#fff}
    .buy.soon{color:var(--faint);border-color:var(--line);cursor:default}
    @media(max-width:820px){.grid{grid-template-columns:1fr}.head h1{font-size:30px}}
  </style>
</BaseLayout>
