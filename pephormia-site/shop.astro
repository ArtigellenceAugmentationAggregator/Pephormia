---
// Shop — PEPHORMIA (Direction B "Lab Bright")
// Drop-in Astro page. Self-contained: tokens inlined so it renders regardless of your
// shared tokens.css. To use your BaseLayout, move the markup into <BaseLayout> and delete
// the inlined <style>/<head>. NOTE: "GHK-Cu Decoded" card is gated ("Launching soon")
// until the citation pass is re-rendered — flip it back to a Buy link when ready.
const title = "Shop — PEPHORMIA";
const description = "Cosmetic-grade peptide topicals, cited digital evidence guides, and print tools — appearance-only, INCI-named.";
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;700&family=Inter:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <style>
/* PEPHORMIA — Direction B "Lab Bright" tokens (locked) */
:root{
  --ink:#0B0D10; --panel:#0F1216; --panel-2:#12161B;
  --line:#1C2127; --line-2:#262C34;
  --cobalt:#1F3BFF; --green:#00A67E; --copper:#D68A4E;
  --amber:#C9A227;
  --text:#E7EAEE; --muted:#8B93A0; --faint:#5B636F;
  --display:'Space Grotesk',system-ui,sans-serif;
  --body:'Inter',system-ui,sans-serif;
  --mono:'IBM Plex Mono',ui-monospace,monospace;
  --maxw:1120px;
}
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{background:var(--ink);color:var(--text);font-family:var(--body);line-height:1.55;-webkit-font-smoothing:antialiased}
a{color:inherit;text-decoration:none}
.wrap{max-width:var(--maxw);margin:0 auto;padding:0 28px}
.mono{font-family:var(--mono);font-size:11px;letter-spacing:.15em;text-transform:uppercase;color:var(--faint)}
.eyebrow{font-family:var(--mono);font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:var(--green)}
h1,h2,h3{font-family:var(--display);font-weight:700;letter-spacing:-.01em;color:#fff;line-height:1.1}

/* nav */
.nav{position:sticky;top:0;z-index:50;background:rgba(11,13,16,.86);backdrop-filter:blur(10px);border-bottom:1px solid var(--line)}
.nav .row{display:flex;align-items:center;justify-content:space-between;height:64px}
.brand{display:flex;align-items:center;gap:10px}
.brand .wm{font-family:var(--display);font-weight:700;font-size:18px;letter-spacing:.05em}
.navlinks{display:flex;gap:26px;align-items:center}
.navlinks a{font-size:13px;color:var(--muted);transition:color .15s}
.navlinks a:hover,.navlinks a.active{color:#fff}
.navlinks a.invest{color:var(--cobalt);font-weight:600}

/* coordinate rail */
.rail{display:flex;justify-content:space-between;border-top:1px solid var(--line);border-bottom:1px solid var(--line);padding:9px 0}
.rail span{font-family:var(--mono);font-size:10px;letter-spacing:.14em;color:var(--faint);text-transform:uppercase}

.foot{border-top:1px solid var(--line);margin-top:70px;padding:34px 0 46px}
.foot .cols{display:flex;justify-content:space-between;gap:30px;flex-wrap:wrap}
.foot .mono{line-height:1.9}
.disc{border:1px solid var(--line);background:var(--panel);padding:16px 18px;margin-top:26px;font-size:12px;color:var(--muted);line-height:1.6}
.disc b{color:#fff}

/* page */

  .shophero{padding:52px 0 30px}
  .shophero h1{font-size:40px;max-width:16ch}
  .shophero p{color:var(--muted);max-width:60ch;margin-top:16px;font-size:15px}
  .streamlabel{display:flex;align-items:baseline;gap:14px;margin:44px 0 18px}
  .streamlabel h2{font-size:22px}
  .streamlabel .tag{font-family:var(--mono);font-size:10px;letter-spacing:.14em;text-transform:uppercase;color:var(--faint)}
  .streamlabel .accent{color:var(--cobalt)}
  .grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--line);border:1px solid var(--line)}
  .card{background:var(--panel);padding:20px 20px 22px;display:flex;flex-direction:column;min-height:250px}
  .card .idx{font-family:var(--mono);font-size:10px;color:var(--faint);letter-spacing:.12em}
  .card h3{font-size:17px;margin:12px 0 4px;line-height:1.2}
  .card .inci{font-family:var(--mono);font-size:10.5px;color:var(--green);letter-spacing:.03em;margin-bottom:10px}
  .card p{font-size:12.5px;color:var(--muted);flex:1;line-height:1.5}
  .card .foot{display:flex;align-items:center;justify-content:space-between;margin-top:16px;border-top:1px solid var(--line);padding-top:14px}
  .card .price{font-family:var(--display);font-weight:700;font-size:18px;color:#fff}
  .card .price small{font-family:var(--mono);font-weight:400;font-size:10px;color:var(--faint);margin-left:4px}
  .card .buy{font-family:var(--mono);font-size:10.5px;letter-spacing:.12em;text-transform:uppercase;color:var(--cobalt);border:1px solid var(--cobalt);padding:7px 12px;transition:.15s}
  .card .buy:hover{background:var(--cobalt);color:#fff}
  .card.free .buy{color:var(--green);border-color:var(--green)}
  .card.free .buy:hover{background:var(--green)}
  .card .stripe{height:3px;margin:-20px -20px 0;background:var(--cobalt)}
  .card.digital .stripe{background:var(--green)} .card.pod .stripe{background:var(--copper)}
  .card.digital .inci{color:var(--muted)} .card.pod .inci{color:var(--copper)}
  .compliance-mini{font-family:var(--mono);font-size:10px;color:var(--faint);margin-top:8px}
  @media(max-width:820px){.grid{grid-template-columns:1fr}.shophero h1{font-size:30px}}

  </style>
</head>
<body>
<nav class="nav"><div class="wrap"><div class="row">
  <a class="brand" href="/">
    <svg width="30" height="29" viewBox="0 0 80 76"><g transform="translate(8,8)">
      <rect x="6" y="18" width="6" height="40" rx="3" fill="#1F3BFF"/>
      <path d="M12 22 h9 a11 11 0 0 1 0 22 h-9 z" fill="none" stroke="#1F3BFF" stroke-width="6"/>
      <rect x="40" y="8" width="6" height="50" rx="3" fill="#1F3BFF"/><rect x="58" y="8" width="6" height="50" rx="3" fill="#1F3BFF"/>
      <rect x="46" y="30" width="12" height="6" rx="3" fill="#1F3BFF"/><circle cx="52" cy="33" r="5.5" fill="#00A67E"/>
    </g></svg><span class="wm">PEPHORMIA</span></a>
  <div class="navlinks">
    <a href="/learn">Learn</a><a href="/library">Library</a><a href="/shop" class="active">Shop</a>
    <a href="/blog">Blog</a><a href="/invest" class="invest">Investors</a>
  </div>
</div></div></nav>

<div class="wrap">
  <section class="shophero">
    <div class="eyebrow">SHOP / SYS.04</div>
    <h1>Cited science, made into products you can actually use.</h1>
    <p>Three ways to buy: cosmetic-grade topicals, cited digital evidence guides, and print tools — all drawn from the
      same graded, honest research core. Cosmetic products describe appearance only; nothing here is a drug or a
      therapeutic claim.</p>
  </section>

  <div class="rail"><span>PH.SHOP</span><span>03 STREAMS</span><span>10 PRODUCTS</span><span>AUD · INCL. GST</span></div>

  <!-- ===== TOPICALS ===== -->
  <div class="streamlabel"><h2>Topicals</h2><span class="tag">Stream 01 · <span class="accent">Cosmetic-grade · AU-made · INCI-named</span></span></div>
  <div class="grid">
    <div class="card"><div class="stripe"></div>
      <span class="idx">01 · SERUM</span>
      <h3>Copper Peptide Radiance Serum</h3>
      <div class="inci">Copper Tripeptide-1 (GHK-Cu) 1%</div>
      <p>A lightweight daily serum for the look of smoother, firmer, more radiant skin. Layers under moisturiser.
        Appearance support only.</p>
      <div class="foot"><span class="price">A$44<small>/30ml</small></span><a class="buy" href="#">Add</a></div>
    </div>
    <div class="card"><div class="stripe"></div>
      <span class="idx">02 · SERUM</span>
      <h3>Multi-Peptide Firming Serum</h3>
      <div class="inci">Palmitoyl Tripeptide-1 · Tetrapeptide-7 · Acetyl Hexapeptide-8</div>
      <p>A multi-peptide blend (Matrixyl + Argireline-type) to help visibly soften the look of fine lines and support
        a firmer-looking complexion.</p>
      <div class="foot"><span class="price">A$42<small>/30ml</small></span><a class="buy" href="#">Add</a></div>
    </div>
    <div class="card"><div class="stripe"></div>
      <span class="idx">03 · EYE & LASH</span>
      <h3>Peptide Eye &amp; Lash Complex</h3>
      <div class="inci">Acetyl Tetrapeptide-3 · Biotinoyl Tripeptide-1</div>
      <p>Targeted care for the look of the eye area and the appearance of fuller-looking lashes and brows. Fragrance-free.</p>
      <div class="foot"><span class="price">A$38<small>/15ml</small></span><a class="buy" href="#">Add</a></div>
    </div>
    <div class="card"><div class="stripe"></div>
      <span class="idx">04 · SCALP</span>
      <h3>Copper Peptide Scalp &amp; Hair Serum</h3>
      <div class="inci">Copper Tripeptide-1 · AHK-Cu</div>
      <p>A dual copper-peptide scalp serum for the appearance of healthier-looking hair. Apply to a clean scalp;
        stay consistent.</p>
      <div class="foot"><span class="price">A$46<small>/60ml</small></span><a class="buy" href="#">Add</a></div>
    </div>
    <div class="card"><div class="stripe"></div>
      <span class="idx">05 · MOISTURISER</span>
      <h3>Peptide Barrier Moisturiser</h3>
      <div class="inci">Copper Tripeptide-1 · Ceramide NP · Niacinamide</div>
      <p>A richer copper-peptide cream to support a smoother, hydrated, healthy-looking barrier. Morning and night.</p>
      <div class="foot"><span class="price">A$40<small>/50ml</small></span><a class="buy" href="#">Add</a></div>
    </div>
    <div class="card"><div class="stripe"></div>
      <span class="idx">06 · SET</span>
      <h3>The Core Routine Set</h3>
      <div class="inci">Serum · Moisturiser · Eye complex</div>
      <p>The three-step appearance routine, bundled. Better value than buying the trio separately.</p>
      <div class="foot"><span class="price">A$108<small>/set</small></span><a class="buy" href="#">Add</a></div>
    </div>
  </div>
  <div class="compliance-mini">INCI names shown. Cosmetic products; appearance/structure-function language only. Not injectable, not scheduled, not a therapeutic product.</div>

  <!-- ===== DIGITAL ===== -->
  <div class="streamlabel"><h2>Digital · The Library</h2><span class="tag">Stream 02 · <span style="color:var(--green)">Cited evidence, graded honestly</span></span></div>
  <div class="grid">
    <div class="card digital free"><div class="stripe"></div>
      <span class="idx">07 · LEAD GUIDE</span>
      <h3>7 FDA-Hearing Peptides</h3>
      <div class="inci">Evidence review · verified clean</div>
      <p>The peptides on the regulatory radar, graded strong / human / weak / mechanistic — with the honest limits of
        each. Free with email.</p>
      <div class="foot"><span class="price">Free</span><a class="buy" href="#">Get it</a></div>
    </div>
    <div class="card digital"><div class="stripe"></div>
      <span class="idx">08 · DECODED</span>
      <h3>Copper Peptides (GHK-Cu) Decoded</h3>
      <div class="inci">Full cited evidence review</div>
      <p>What the peer-reviewed record actually shows for GHK-Cu — every claim tiered and sourced, with the honesty
        line on every one. Final citation pass in progress.</p>
      <div class="foot"><span class="price" style="color:var(--faint)">Soon</span><span class="buy" style="color:var(--faint);border-color:var(--line);cursor:default">Launching soon</span></div>
    </div>
    <div class="card digital"><div class="stripe"></div>
      <span class="idx">09 · LIBRARY</span>
      <h3>The Peptide Evidence Library</h3>
      <div class="inci">Bundle · all current guides</div>
      <p>Every graded evidence review in one bundle — the full honest picture across sleep, recovery, skin, focus and
        longevity.</p>
      <div class="foot"><span class="price">A$39</span><a class="buy" href="#">Buy</a></div>
    </div>
  </div>

  <!-- ===== POD ===== -->
  <div class="streamlabel"><h2>Print</h2><span class="tag">Stream 03 · <span style="color:var(--copper)">Print-on-demand · ships worldwide</span></span></div>
  <div class="grid">
    <div class="card pod"><div class="stripe"></div>
      <span class="idx">10 · JOURNAL</span>
      <h3>Peptide Protocol Planner</h3>
      <div class="inci">Undated · 90 days · A5</div>
      <p>Track routine, consistency and appearance changes over a full cycle. Built around the honest 8–12 week
        timelines.</p>
      <div class="foot"><span class="price">A$24</span><a class="buy" href="#">Buy</a></div>
    </div>
    <div class="card pod"><div class="stripe"></div>
      <span class="idx">11 · JOURNAL</span>
      <h3>90-Day Skin &amp; Longevity Journal</h3>
      <div class="inci">Guided · daily prompts</div>
      <p>A daily habit journal for skin and longevity routines, with cited micro-education woven through.</p>
      <div class="foot"><span class="price">A$26</span><a class="buy" href="#">Buy</a></div>
    </div>
    <div class="card pod"><div class="stripe"></div>
      <span class="idx">12 · WALL ART</span>
      <h3>Lab-Bright Print Set</h3>
      <div class="inci">Set of 3 · matte · A3</div>
      <p>The evidence-tier system and peptide map as clean scientific wall prints. Ships print-on-demand.</p>
      <div class="foot"><span class="price">A$29</span><a class="buy" href="#">Buy</a></div>
    </div>
  </div>
</div>

<footer class="foot"><div class="wrap">
  <div class="cols">
    <div class="mono">PEPHORMIA<br>AN ARTIGELLENCE VENTURE<br>SYDNEY · AU</div>
    <div class="mono">LEARN · LIBRARY · SHOP<br>BLOG · INVESTORS<br>PEPHORMIA.COM</div>
    <div class="mono">ABN 83 988 690 362<br>RAJ@ARTIGELLENCE.COM<br>+61 469 313 323</div>
  </div>
  <div class="disc">
    <b>Compliance.</b> All topical products are cosmetic-grade and described by appearance and structure-function
    only — they are not injectable, not scheduled, and make no therapeutic or disease claims. Educational content
    grades published evidence and is not medical advice; always consult a qualified professional. Prices in AUD, incl. GST.
  </div>
</div></footer>
</body>
</html>
